{
  "name": "big-stick-worm-api",
  "version": "1.0.0",
  "description": "Worm Tamagotchi backend — Express + SQLite, designed for offline Mac Mini hosting",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:reset": "rm -f worms.db && tsx src/server.ts --migrate-only"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
